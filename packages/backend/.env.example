# Copy to .env and fill in real values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Prisma)
# MySQL:  DATABASE_URL="mysql://root:password@localhost:3306/lms_crm"
# SQLite: DATABASE_URL="file:./dev.db"
DATABASE_URL="file:./dev.db"

# JWT — use long random strings in production (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (outbound email for quotation / agreement PDFs)
# Leave SMTP_HOST blank in dev — mailer falls back to a JSON transport that logs instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Trivarta Tech <noreply@trivarta.in>"

# Mag91 WhatsApp (Indian BSP)
# Leave MAG91_API_KEY blank to disable; send calls will no-op with { skipped: true }.
MAG91_API_KEY=
MAG91_SENDER_ID=
MAG91_BASE_URL=https://api.mag91.com

# Expo Push Notifications
# Optional. Required only if you have enhanced security enabled on your Expo project.
EXPO_ACCESS_TOKEN=
