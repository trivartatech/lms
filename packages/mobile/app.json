{
  "expo": {
    "name": "LMS CRM",
    "slug": "lms-crm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lmscrm",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lmscrm.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.lmscrm.app"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "apiBaseUrl": "https://lms.trivarta.in/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1abaa2ca-b145-444d-a02c-ad6986db7f25"
      }
    },
    "owner": "trivarta"
  }
}
