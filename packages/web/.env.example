# Copy to .env.local to override. All vars exposed to the client MUST be prefixed VITE_.
# Do not put secrets here — this bundle is public.

# The dev server proxies /api → this URL. Default is http://localhost:3001.
# Uncomment and set if your backend runs elsewhere (e.g. different port or LAN host).
# VITE_API_PROXY_TARGET=http://localhost:3001
